# DTCWriter Proxy Server — Environment Variables
# Copy this to .env and fill in your values

# Server port (default: 3000)
PORT=3000

# Session secret — CHANGE THIS in production!
SESSION_SECRET=dtcwriter-change-this-secret-in-production

# (Optional) If you add a database later, connection string goes here
# DATABASE_URL=postgres://user:pass@localhost:5432/dtcwriter
